<?xml version="1.0" encoding="utf-8"?>
<!--
מטרת הקובץ:
מסך עריכת לוק בסגנון הבהיר החדש.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitleEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="עריכת לוק ⚙️"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="26sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreview"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/divider_color"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/bg_light"
                android:scaleType="fitCenter"
                android:alpha="0.8" />
                
            <!-- כפתור שינוי תמונה מעל התמונה -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#40000000" />
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickImage"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="עדכון תמונה"
                android:textColor="@color/white"
                app:strokeColor="@color/white"
                app:cornerRadius="14dp"
                android:layout_gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TextView ריק שמתעדכן ב-View -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/cardPreview"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:hint="כותרת חדשה"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvHint"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_field"
            android:hint="תיאור מחודש"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etTags"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:hint="האשטגים (מופרדים בפסיק)"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etDesc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- לחצני פעולה -->
        <LinearLayout
            android:id="@+id/actionsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/etTags"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:layout_height="60dp"
                android:text="שמירת שינויים"
                android:textColor="@color/white"
                android:backgroundTint="@color/purple_gradient_end"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="30dp"
                android:layout_marginEnd="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:text="מחיקה"
                android:textColor="@color/error_color"
                app:strokeColor="@color/error_color"
                app:cornerRadius="30dp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/pink_gradient_start"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/actionsLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" 
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    
</androidx.core.widget.NestedScrollView>
