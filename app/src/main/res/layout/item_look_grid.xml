<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/bg_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layoutDirection="rtl">

        <!-- Background Image -->
        <ImageView
            android:id="@+id/ivLook"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery" />

        <!-- Gradient Overlay at bottom for readable text -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/bg_gradient_text_overlay"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Floating favorite button (white circle, pink heart) -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/ivFavorite"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="14dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/details_favorites"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_favorites"
            app:tint="@color/pink_gradient_start"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="מעיל חורף אלגנטי"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:layout_marginHorizontal="12dp"
            app:layout_constraintBottom_toTopOf="@id/tvUserName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Username -->
        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="נועה כהן"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
