<?xml version="1.0" encoding="utf-8"?>
<!--
מטרת הקובץ:
מסך יצירת לוק חדש (Upload) בעיצוב הבהיר החדש.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp"> <!-- מרווח לתפריט תחתון -->

        <!-- מעטפת גרדיאנט עליונה (האדר) -->
        <View
            android:id="@+id/headerBg"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_gradient_bottom_corners"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="צור לוק חדש ✨"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שתפי את הסטייל שלך"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- כותרת תמונה -->
        <TextView
            android:id="@+id/tvImageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="תמונה"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/headerBg"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- אזור בחירת תמונה -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImagePicker"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/divider_color"
            app:strokeWidth="1dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvImageLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>
                
            <!-- כפתורי בחירת התמונה (מוצגים כשאין תמונה) -->
            <LinearLayout
                android:id="@+id/llPickerButtons"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="2"
                android:gravity="center"
                android:padding="24dp">
                
                <LinearLayout
                    android:id="@+id/btnGallery"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_light_pink_button"
                    android:layout_marginEnd="8dp">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/pink_gradient_start"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="בחרי מהגלריה"
                        android:textColor="@color/pink_gradient_start"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCamera"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_light_purple_button"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/purple_gradient_end"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="צלמי תמונה"
                        android:textColor="@color/purple_gradient_end"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- כותרת "כותרת" -->
        <TextView
            android:id="@+id/tvTitleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="כותרת"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardImagePicker"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etLookTitle"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:hint="תני שם ללוק שלך..."
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- תיאור -->
        <TextView
            android:id="@+id/tvDescLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="תיאור"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/etLookTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etLookDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:gravity="top|start"
            android:background="@drawable/bg_input_field"
            android:hint="ספרי לנו על הלוק - איפה את לובשת אותו?\nמה השילוב האהוב עליך?"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDescLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- האשטגים -->
        <TextView
            android:id="@+id/tvTagsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="האשטגים (מופרדים בפסיק)"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/etLookDesc"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etLookTags"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:hint="לדוגמה: אופנה, קיץ, קז'ואל"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTagsLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- כפתור שמירה קיים במערכת, נעצב אותו למקרה שהוא נחוץ בדף זה -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveLook"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_gradient_button"
            android:text="שמירת לוק"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@+id/etLookTags"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
